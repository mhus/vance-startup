# Copy to .env and adjust before running `docker compose up`.
# .env is gitignored — never commit your secrets.

# --- Image source ---------------------------------------------------------
# Docker Hub namespace and image tag for vance-brain / vance-face.
# The setup wizard pulls vance-anus from the same namespace.
VANCE_IMAGE_NAMESPACE=mhus
IMAGE_TAG=latest

# --- MongoDB --------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=example
VANCE_MONGODB_DATABASE=vance

# Host port for MongoDB. Change if a host-side Mongo already binds 27017.
MONGO_PORT=27017

# --- Brain ----------------------------------------------------------------
# CHANGE THESE before exposing the stack to anything beyond localhost.
VANCE_ENCRYPTION_PASSWORD=changeit
VANCE_INTERNAL_TOKEN=changeit-internal
VANCE_BOOTSTRAP_ACME=false

# Host port for the Brain REST/WS API. Default 9990.
BRAIN_PORT=9990

# JVM options for the Brain container.
BRAIN_JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75.0

# --- Web UI ---------------------------------------------------------------
# Host port for the Web UI. Default 8080 → http://localhost:8080.
FACE_PORT=8080
