# Copy to .env and adjust before running `docker compose up`.
# .env is gitignored — never commit your secrets.

# --- Image source ---------------------------------------------------------
# Docker Hub namespace and image tag for vance-brain / vance-face / vance-anus.
VANCE_IMAGE_NAMESPACE=mhus
IMAGE_TAG=latest

# --- MongoDB --------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=example
VANCE_MONGODB_DATABASE=vance

# Host port for MongoDB. Change if a host-side Mongo already binds 27017.
MONGO_PORT=27017

# --- Brain ----------------------------------------------------------------
# CHANGE THESE before exposing the stack to anything beyond localhost.
VANCE_ENCRYPTION_PASSWORD=changeit
VANCE_INTERNAL_TOKEN=changeit-internal
VANCE_BOOTSTRAP_ACME=false

# Host port for the Brain REST/WS API. Default 9990.
BRAIN_PORT=9990

# JVM options for the Brain container.
BRAIN_JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75.0

# --- Redis (live features) ------------------------------------------------
# The Brain is started with VANCE_REDIS_ENABLED=true in this variant.
# Override the URI only if you point the Brain at an external Redis
# instead of the bundled container.
VANCE_REDIS_URI=redis://redis:6379
REDIS_PORT=6379

# --- Web UI ---------------------------------------------------------------
# Host port for the Web UI. Default 8080 → http://localhost:8080.
FACE_PORT=8080

# --- mongo-express (profile: admin) ---------------------------------------
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=admin
MONGO_EXPRESS_PORT=9081

# --- Anus admin shell (profile: tools) ------------------------------------
# BCrypt hash, generated via `docker compose run --rm anus hash --plain <pw>`.
# Without this, the anus container starts but every command is rejected.
# NOT required for `docker compose run --rm anus --setup` (first-time
# wizard runs without a password gate).
VANCE_ANUS_PASSWORD_HASH=
VANCE_ANUS_TIMEOUT=10m
